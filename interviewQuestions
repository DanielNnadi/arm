// interviewQuestions.js – 50 companies, 20 questions each (1000+ Q&As)
const interviewQuestionsDB = {};

// List of 50 real tech / fintech / consulting companies
const companyNames = [
  "google", "microsoft", "apple", "amazon", "meta", "netflix", "tesla", "nvidia", "intel", "amd",
  "salesforce", "oracle", "ibm", "cisco", "adobe", "paypal", "uber", "airbnb", "spotify", "twitter",
  "linkedin", "snapchat", "pinterest", "dropbox", "slack", "zoom", "square", "stripe", "shopify",
  "roblox", "epicgames", "unity", "mongodb", "datadog", "cloudflare", "palantir", "vmware", "dell",
  "hp", "lenovo", "samsung", "huawei", "sony", "nokia", "ericsson", "qualcomm", "broadcom", "micron",
  "westernDigital", "seagate"
];

// Question templates (20 generic but realistic interview questions)
const questionTemplates = [
  { q: "Why do you want to work at [COMPANY]?", a: "I admire [COMPANY]'s innovation and impact. I want to contribute to solving challenging problems." },
  { q: "Describe a time you faced a technical challenge.", a: "I once debugged a memory leak that was causing crashes. I used profiling tools and fixed it." },
  { q: "How do you stay updated with technology?", a: "I follow tech blogs, take courses, and build side projects." },
  { q: "Tell me about a project you're proud of.", a: "I built an analytics dashboard that reduced reporting time by 50%." },
  { q: "How do you handle tight deadlines?", a: "Prioritise tasks, communicate risks early, and focus on MVP." },
  { q: "What is your favourite programming language?", a: "Python for its versatility and readability." },
  { q: "How do you ensure code quality?", a: "Code reviews, unit tests, and static analysis." },
  { q: "Describe a time you disagreed with a teammate.", a: "I proposed a prototype to compare approaches; we chose the better one." },
  { q: "What is your experience with cloud computing?", a: "I've used AWS/Azure/GCP for deployments and serverless functions." },
  { q: "How do you prioritise features?", a: "By business value, user impact, and technical dependencies." },
  { q: "What is your understanding of our company's mission?", a: "I've researched and it resonates with my values of innovation and customer focus." },
  { q: "How would you improve our product?", a: "I would gather user feedback and analyse metrics to find friction points." },
  { q: "Tell me about a time you failed.", a: "I missed a deadline due to poor estimation; now I use time tracking." },
  { q: "How do you handle stress?", a: "I break problems into small steps and take short breaks." },
  { q: "Why should we hire you?", a: "I bring strong problem‑solving skills and a growth mindset." },
  { q: "What is your experience with agile methodologies?", a: "I've worked in Scrum teams, using Jira for task management." },
  { q: "How do you mentor junior developers?", a: "I pair program and conduct code reviews with constructive feedback." },
  { q: "What is your approach to security?", a: "Follow best practices, sanitise inputs, and keep dependencies updated." },
  { q: "How do you handle production incidents?", a: "Follow incident response plan, communicate, and conduct blameless post‑mortems." },
  { q: "Where do you see yourself in 5 years?", a: "As a technical lead who mentors others and drives product innovation." }
];

// Build the database
companyNames.forEach(company => {
  const companyDisplay = company.charAt(0).toUpperCase() + company.slice(1);
  const questions = questionTemplates.map(t => ({
    question: t.q.replace("[COMPANY]", companyDisplay),
    answer: t.a.replace("[COMPANY]", companyDisplay)
  }));
  interviewQuestionsDB[company] = questions;
});

// Helper function to get questions for a company
function getInterviewQuestions(companyId) {
  return interviewQuestionsDB[companyId] || [];
}
